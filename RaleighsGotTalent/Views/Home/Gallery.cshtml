@{
    ViewData["Title"] = "Gallery";
}

<!-- Hero Section -->
<div class="bg-dark text-white py-5 mb-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold text-warning">Gallery</h1>
        <p class="lead">Memories from every year of Raleigh's Got Talent</p>
    </div>
</div>

<div class="container-fluid px-4">

    <!-- 2025 Section -->
    <div class="mb-5">
        <h2 class="fw-bold text-center mb-4">
            <span class="border-bottom border-warning border-3 pb-2">2025</span>
        </h2>

        <div class="row g-3">
            <div class="col-md-8">
                <img src="https://picsum.photos/900/500?random=1"
                     class="img-fluid rounded shadow w-100"
                     style="height: 500px; object-fit: cover;"
                     alt="2025 Main Show" />
            </div>

            <div class="col-md-4 d-flex flex-column">
                <img src="https://picsum.photos/400/240?random=2"
                     class="img-fluid rounded shadow mb-3"
                     style="height: 240px; object-fit: cover;"
                     alt="2025 Bollywood" />
                <img src="https://picsum.photos/400/240?random=3"
                     class="img-fluid rounded shadow"
                     style="height: 240px; object-fit: cover;"
                     alt="2025 Hip Hop" />
            </div>

            <div class="col-md-4">
                <img src="https://picsum.photos/600/300?random=4"
                     class="img-fluid rounded shadow w-100"
                     style="height: 300px; object-fit: cover;"
                     alt="2025 Contemporary" />
            </div>
            <div class="col-md-4">
                <img src="https://picsum.photos/600/300?random=5"
                     class="img-fluid rounded shadow w-100"
                     style="height: 300px; object-fit: cover;"
                     alt="2025 Winners" />
            </div>
            <div class="col-md-4">
                <img src="https://picsum.photos/600/300?random=6"
                     class="img-fluid rounded shadow w-100"
                     style="height: 300px; object-fit: cover;"
                     alt="2025 Crowd" />
            </div>
        </div>
    </div>

    <hr class="border-warning border-2 my-5" />

    <!-- 2024 Section -->
    <div class="mb-5">
        <h2 class="fw-bold text-center mb-4">
            <span class="border-bottom border-warning border-3 pb-2">2024</span>
        </h2>

        <div class="row g-3">
            <div class="col-md-4 d-flex flex-column">
                <img src="https://picsum.photos/400/240?random=7"
                     class="img-fluid rounded shadow mb-3"
                     style="height: 240px; object-fit: cover;"
                     alt="2024 Opening" />
                <img src="https://picsum.photos/400/240?random=8"
                     class="img-fluid rounded shadow"
                     style="height: 240px; object-fit: cover;"
                     alt="2024 Bollywood" />
            </div>

            <div class="col-md-8">
                <img src="https://picsum.photos/900/500?random=9"
                     class="img-fluid rounded shadow w-100"
                     style="height: 500px; object-fit: cover;"
                     alt="2024 Main Show" />
            </div>

            <div class="col-md-12">
                <img src="https://picsum.photos/1200/300?random=10"
                     class="img-fluid rounded shadow w-100"
                     style="height: 300px; object-fit: cover;"
                     alt="2024 Full Cast" />
            </div>
        </div>
    </div>

    <hr class="border-warning border-2 my-5" />

    <!-- 2023 Section -->
    <div class="mb-5">
        <h2 class="fw-bold text-center mb-4">
            <span class="border-bottom border-warning border-3 pb-2">2023</span>
        </h2>

        <div class="row g-3">
            <div class="col-md-4">
                <img src="https://picsum.photos/600/350?random=11"
                     class="img-fluid rounded shadow w-100"
                     style="height: 350px; object-fit: cover;"
