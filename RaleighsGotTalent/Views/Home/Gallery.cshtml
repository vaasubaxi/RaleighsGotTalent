            </div>

            <div class="col-md-12">
                <img src="https://picsum.photos/1200/300?random=14"
                     class="img-fluid rounded shadow w-100"
                     style="height: 300px; object-fit: cover;"
                     alt="2023 Full Cast" />
            </div>
        </div>
    </div>

</div>