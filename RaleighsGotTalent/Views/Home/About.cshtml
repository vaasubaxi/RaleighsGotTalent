@{
    ViewData["Title"] = "About";
}

<!-- Hero Section -->
<div class="bg-dark text-white py-5 mb-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold text-warning">About Us</h1>
        <p class="lead">Learn more about Raleigh's Got Talent and our mission</p>
    </div>
</div>

<!-- About Content -->
<div class="container">
    <div class="row">
        <div class="col-md-6">
            <h2 class="fw-bold mb-3">Who We Are</h2>
            <p>Raleigh's Got Talent is an annual dance competition celebrating the diverse cultures and talents of the Raleigh community. We bring together performers from all backgrounds to showcase their passion for dance.</p>
            <p>Our competition features three exciting categories — Bollywood, Hip Hop, and Contemporary — spanning multiple age groups to give everyone a chance to shine.</p>
        </div>
        <div class="col-md-6">
            <h2 class="fw-bold mb-3">Our Mission</h2>
            <p>Our mission is to provide a platform for dancers of all ages and backgrounds to express themselves, compete fairly, and celebrate the art of dance in the heart of Raleigh, NC.</p>
            <p>Every year we bring new themes, new talent, and unforgettable performances to our audience.</p>
        </div>
    </div>

    <hr class="my-5" />

    <!-- Stats Row -->
    <div class="row text-center mb-5">
        <div class="col-md-4">
            <h2 class="display-5 fw-bold text-warning">3</h2>
            <p class="text-muted">Dance Categories</p>
        </div>
        <div class="col-md-4">
            <h2 class="display-5 fw-bold text-warning">3</h2>
            <p class="text-muted">Age Groups</p>
        </div>
        <div class="col-md-4">
            <h2 class="display-5 fw-bold text-warning">100+</h2>
            <p class="text-muted">Performers Every Year</p>
        </div>
    </div>
</div>