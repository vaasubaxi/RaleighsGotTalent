@{
    ViewData["Title"] = "Contact";
}

<!-- Hero Section -->
<div class="bg-dark text-white py-5 mb-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold text-warning">Contact Us</h1>
        <p class="lead">Get in touch with the Raleigh's Got Talent team</p>
    </div>
</div>

<div class="container">
    <div class="row g-5">

        <!-- Contact Form -->
        <div class="col-md-7">
            <h2 class="fw-bold mb-4">Send Us a Message</h2>
            <form>
                <div class="mb-3">
                    <label class="form-label fw-bold">Full Name</label>
                    <input type="text" class="form-control" placeholder="Enter your full name" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Email Address</label>
                    <input type="email" class="form-control" placeholder="Enter your email" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Subject</label>
                    <select class="form-select">
                        <option value="">Select a subject</option>
                        <option value="registration">Registration Question</option>
                        <option value="schedule">Schedule Information</option>
                        <option value="general">General Inquiry</option>
                        <option value="sponsorship">Sponsorship</option>
                        <option value="other">Other</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Message</label>
                    <textarea class="form-control" rows="5" placeholder="Write your message here"></textarea>
                </div>
                <button type="submit" class="btn btn-warning fw-bold px-4">
                    Send Message
                </button>
            </form>
        </div>

        <!-- Contact Info -->
        <div class="col-md-5">
            <h2 class="fw-bold mb-4">Get In Touch</h2>

            <div class="card border-0 shadow-sm p-4 mb-4">
                <div class="d-flex align-items-center mb-3">
                    <span class="fs-3 me-3">📧</span>
                    <div>
                        <p class="fw-bold mb-0">Email</p>
                        <p class="text-muted mb-0">info@raleighsgottalent.com</p>
                    </div>
                </div>
                <div class="d-flex align-items-center mb-3">
                    <span class="fs-3 me-3">📍</span>
                    <div>
                        <p class="fw-bold mb-0">Location</p>
                        <p class="text-muted mb-0">Raleigh, NC</p>
                    </div>
                </div>
                <div class="d-flex align-items-center">
                    <span class="fs-3 me-3">📱</span>
                    <div>
                        <p class="fw-bold mb-0">Social Media</p>
                        <p class="text-muted mb-0">RaleighsGotTalent</p>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold text-warning mb-3">Competition Inquiries</h5>
                <p class="text-muted small mb-2">For registration questions please visit our registration page or send us an email.</p>
                <p class="text-muted small mb-0">We typically respond within 2 to 3 business days.</p>
            </div>

        </div>
    </div>
</div>