@{
    ViewData["Title"] = "Schedule";
}

<!-- Hero Section -->
<div class="bg-dark text-white py-5 mb-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold text-warning">Event Schedule</h1>
        <p class="lead">Performance lineup and timing for Raleigh's Got Talent 2026</p>
    </div>
</div>

<div class="container">

    <!-- Event Info -->
    <div class="row mb-5">
        <div class="col-md-4">
            <div class="card text-center border-0 shadow-sm p-3">
                <h4 class="text-warning">📅 Date</h4>
                <p class="mb-0">TBA</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center border-0 shadow-sm p-3">
                <h4 class="text-warning">📍 Location</h4>
                <p class="mb-0">TBA</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center border-0 shadow-sm p-3">
                <h4 class="text-warning">🕐 Time</h4>
                <p class="mb-0">TBA</p>
            </div>
        </div>
    </div>

    <!-- Schedule Table -->
    <h2 class="fw-bold mb-4">Performance Order</h2>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Team Name</th>
                    <th>Category</th>
                    <th>Age Group</th>
                    <th>Time Slot</th>
                </tr>
            </thead>
            <tbody>
